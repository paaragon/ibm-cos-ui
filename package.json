{
  "name": "ibm-cos-ui",
  "version": "1.0.0",
  "description": "Desktop app to manage IBM Cloud Object Storage",
  "main": "dist-electron/electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run build:electron && NODE_ENV=development electron .\" \"npm run dev:vite\"",
    "dev:vite": "vite",
    "build": "npm run build:electron && npm run build:renderer && electron-builder",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron": "electron .",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "ibm",
    "cloud",
    "object-storage"
  ],
  "author": "IBM COS UI Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "ibm-cos-sdk": "^1.14.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "lucide-react": "^0.294.0"
  },
  "build": {
    "appId": "com.ibm.cos-ui",
    "productName": "IBM COS UI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/",
      "dist/",
      "node_modules/"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icons/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/icon-512.png"
    }
  }
}